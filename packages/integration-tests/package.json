{
  "name": "@radiantscript/integration-tests",
  "version": "0.1.0",
  "description": "Cross-repository E2E integration tests for the Radiant ecosystem",
  "private": true,
  "scripts": {
    "test": "jest --config jest.config.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:contracts": "jest --testPathPattern=contracts",
    "test:wallet": "jest --testPathPattern=wallet",
    "test:electrum": "jest --testPathPattern=electrum",
    "test:e2e": "jest --testPathPattern=e2e"
  },
  "keywords": [
    "radiant",
    "integration-tests",
    "e2e"
  ],
  "license": "MIT",
  "devDependencies": {
    "@radiantblockchain/constants": "github:Radiant-Core/radiantblockchain-constants",
    "@radiantblockchain/radiantjs": "github:Radiant-Core/radiantjs",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3",
    "ws-electrumx-client": "^1.0.5"
  }
}
