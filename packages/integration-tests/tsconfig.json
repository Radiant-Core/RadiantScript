{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./tests",
    "declaration": true,
    "resolveJsonModule": true,
    "moduleResolution": "node16",
    "typeRoots": ["./tests/types", "./node_modules/@types"]
  },
  "include": ["tests/**/*", "tests/types/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
